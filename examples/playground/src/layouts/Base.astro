---
import "@fontsource/ibm-plex-serif/600.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles.css";
import Toolbar from "../components/Toolbar.astro";

const { title, description } = Astro.props as {
  title: string;
  description: string;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' rx='3' fill='%2320242B'/%3E%3Crect x='3' y='9' width='10' height='4' fill='%23FFE24A'/%3E%3Crect x='3' y='3' width='10' height='2' fill='%23FAF9F6'/%3E%3Crect x='3' y='6.2' width='7' height='1.4' fill='%2371767F'/%3E%3C/svg%3E"
    />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.dataset.theme = "light";
    </script>
  </head>
  <body>
    <Toolbar />
    <div class="site-shell">
      <slot />
      <footer class="footer">
        <a
          href="https://github.com/Invalid8/better-content"
          target="_blank"
          rel="noreferrer"
        >
          github.com/Invalid8/better-content
        </a>
        <a
          href="https://better-content-docs.vercel.app"
          target="_blank"
          rel="noreferrer"
        >
          docs
        </a>
        <a
          href="https://www.npmjs.com/package/better-content"
          target="_blank"
          rel="noreferrer"
        >
          npm
        </a>
        <span>MIT · framework-neutral content engine</span>
      </footer>
    </div>
  </body>
</html>
