<div class="adapter-lab">
  <aside class="adapter-picker">
    <p class="bar-label">active adapter</p>
    <div class="adapter-choices" id="adapter-choices"></div>
    <p class="adapter-note">
      Switching reloads the page and hands the same engine a different
      backend. PGlite keeps your edits in IndexedDB; the other two reset. The
      mock REST adapter logs every call to the browser console.
    </p>
    <button class="btn" type="button" id="reset-demo">Reset demo data</button>
  </aside>

  <div class="query-console">
    <div class="panel-bar">
      <span class="bar-label">query console</span>
      <code>adapter.fetchCollection(collection, query)</code>
      <span class="row-pill" id="row-pill">…</span>
    </div>
    <div class="query-row">
      <label>
        collection
        <select id="query-collection">
          <option value="page">page</option>
          <option value="cards">cards</option>
        </select>
      </label>
      <label>
        query (neutral, adapter-validated)
        <textarea id="query-json" spellcheck="false" rows="3">{`{ "orderBy": [{ "field": "order", "direction": "asc" }] }`}</textarea>
      </label>
      <button class="btn primary" type="button" id="run-query">Run</button>
    </div>
    <pre class="query-output" id="query-output">loading rows…</pre>
    <p class="adapter-note">
      Unsupported operations throw instead of silently degrading. Try
      <code>{`{ "filters": [{ "field": "title", "op": "contains", "value": "row" }] }`}</code>
      on the cards collection and compare adapters.
    </p>
  </div>
</div>

<script>
  import { registerDataInspector } from "better-content/devtools";
  import type { DataInspectorElement } from "better-content/devtools";
  import { ready } from "../lib/engine";
  import {
    activeAdapterId,
    adapter,
    adapterOptions,
    resetDemo,
    setAdapter,
  } from "../lib/db";

  // The floating "your database" button is better-content/devtools,
  // shipped with the package. This is all it takes to mount it.
  registerDataInspector();
  const inspector = document.createElement(
    "better-content-inspector",
  ) as DataInspectorElement;
  inspector.collections = ["page", "cards"];
  inspector.adapter = adapter;
  document.body.append(inspector);
  void ready.then((engine) => {
    inspector.engine = engine;
  });

  // Adapter picker.
  const choices = document.getElementById("adapter-choices")!;
  for (const option of adapterOptions) {
    const button = document.createElement("button");
    button.type = "button";
    button.className = "adapter-choice";
    button.setAttribute(
      "aria-pressed",
      String(option.id === activeAdapterId),
    );
    button.innerHTML = `<strong>${option.label}</strong><span>${option.caption}</span>`;
    button.addEventListener("click", () => {
      if (option.id !== activeAdapterId) setAdapter(option.id);
    });
    choices.append(button);
  }

  document
    .getElementById("reset-demo")!
    .addEventListener("click", () => void resetDemo());

  // Query console.
  const collectionSelect = document.getElementById(
    "query-collection",
  ) as HTMLSelectElement;
  const queryJson = document.getElementById("query-json") as HTMLTextAreaElement;
  const output = document.getElementById("query-output")!;
  const rowPill = document.getElementById("row-pill")!;

  async function runQuery() {
    try {
      const query = queryJson.value.trim()
        ? JSON.parse(queryJson.value)
        : undefined;
      const rows = await adapter.fetchCollection(collectionSelect.value, query);
      output.dataset.kind = "ok";
      output.textContent = JSON.stringify(
        rows,
        (_key, value: unknown) =>
          typeof value === "string" && value.length > 72
            ? `${value.slice(0, 69)}…`
            : value,
        2,
      );
      rowPill.textContent = `${rows.length} rows`;
    } catch (error) {
      output.dataset.kind = "error";
      output.textContent =
        error instanceof Error ? error.message : "Unknown query error";
      rowPill.textContent = "error";
    }
  }

  document
    .getElementById("run-query")!
    .addEventListener("click", () => void runQuery());
  queryJson.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key === "Enter") {
      void runQuery();
    }
  });

  // Refresh after every save so edits show up as rows.
  void ready.then((engine) => {
    engine.subscribe(() => {
      if (!engine.getSnapshot().saving) void runQuery();
    });
    void runQuery();
  });
</script>
